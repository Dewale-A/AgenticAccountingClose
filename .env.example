# =============================================================
# Environment Configuration
# Copy this file to .env and fill in your API keys
# =============================================================

# OpenAI API Key (required for embeddings and LLM calls)
OPENAI_API_KEY=your-openai-api-key-here

# Model Configuration
OPENAI_MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-ada-002

# =============================================================
# SOX Governance Settings
# These thresholds control segregation of duties, materiality
# gates, and human-in-the-loop escalation points.
# =============================================================

# Journal entries above this amount require manager approval
MATERIALITY_THRESHOLD_L1=10000

# Journal entries above this amount require controller approval
MATERIALITY_THRESHOLD_L2=50000

# Journal entries above this amount require CFO approval
MATERIALITY_THRESHOLD_L3=250000

# Reconciliation variance above this percentage triggers review
RECON_VARIANCE_THRESHOLD_PCT=1.0

# Variance analysis: actuals vs budget deviation triggering explanation
FLUX_ANALYSIS_THRESHOLD_PCT=5.0

# Confidence score below this triggers human review (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.7

# Enable full SOX audit trail logging
SOX_AUDIT_TRAIL_ENABLED=true

# Enable segregation of duties enforcement
SEGREGATION_OF_DUTIES_ENABLED=true

# =============================================================
# Application Settings
# =============================================================

API_HOST=0.0.0.0
API_PORT=8000
DATABASE_PATH=src/data/accounting.db

# Close period (current month being closed)
CLOSE_PERIOD=2026-02
